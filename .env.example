# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://wildtrack_user:wildtrack_password@localhost:5432/wildtrack_db?schema=public"
PORT=3000
NODE_ENV=development
JWT_SECRET=

# Cloudinary — image storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# iNaturalist Vision API — species identification from photos
# Obtain a JWT by POSTing your credentials to https://www.inaturalist.org/users/api_token
# or via OAuth at https://www.inaturalist.org/oauth/applications
# If unset, AI prediction is skipped and observations still save normally.
INATURALIST_API_TOKEN=